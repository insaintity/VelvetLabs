{
  "name": "velvet",
  "version": "0.1.0",
  "private": true,
  "description": "Velvet AI album foundry.",
  "author": "insaintity",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:railway": "node .next/standalone/server.js",
    "start:combined": "node workers/combined-service.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "worker": "tsx workers/velvet-worker.ts",
    "worker:once": "tsx workers/velvet-worker.ts --once",
    "desktop:prepare": "npm run build && node scripts/prepare-desktop.mjs",
    "desktop:prepare:fast": "node scripts/prepare-desktop.mjs --reuse-build",
    "desktop:preview": "npm run desktop:prepare && electron .",
    "desktop:preview:fast": "npm run desktop:prepare:fast && electron .",
    "desktop:dist": "npm run desktop:prepare && electron-builder --win portable",
    "desktop:dist:fast": "npm run desktop:prepare:fast && electron-builder --win portable"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.6",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "studio.velvet.desktop",
    "productName": "Velvet",
    "artifactName": "Velvet-${version}-Windows-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/main.cjs",
      "desktop/preload.cjs",
      "package.json"
    ],
    "extraResources": [
      { "from": "desktop-dist/app-server", "to": "app-server" },
      { "from": "desktop-dist/app-server/node_modules", "to": "app-server/node_modules" },
      { "from": "desktop-dist/velvet-worker.cjs", "to": "velvet-worker.cjs" },
      { "from": "desktop-dist/ffmpeg", "to": "ffmpeg" },
      { "from": "desktop-dist/velvet-icon.png", "to": "velvet-icon.png" }
    ],
    "win": {
      "icon": "app/icon.png",
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    }
  }
}
